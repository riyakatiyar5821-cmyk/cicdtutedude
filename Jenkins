pipeline {
    agent any

    environment {
        BACKEND_DIR = "backend"
        FRONTEND_DIR = "frontend"
    }

    stages {

        stage('Clone Repository') {
            steps {
                git branch: 'main', url: 'https://github.com/riyakatiyar5821-cmyk/cicdtutedude.git'
            }
        }

        stage('Install Backend Dependencies (Flask)') {
            steps {
                dir("${BACKEND_DIR}") {
                    sh '''
                    python3 -m pip install --upgrade pip
                    pip3 install -r requirements.txt
                    '''
                }
            }
        }

        stage('Install Frontend Dependencies (Express)') {
            steps {
                dir("${FRONTEND_DIR}") {
                    sh '''
                    npm install
                    '''
                }
            }
        }

        stage('Restart Backend (Flask)') {
            steps {
                dir("${BACKEND_DIR}") {
                    sh '''
                    pm2 restart flask-backend || \
                    pm2 start app.py --name flask-backend --interpreter python3
                    '''
                }
            }
        }

        stage('Restart Frontend (Express)') {
            steps {
                dir("${FRONTEND_DIR}") {
                    sh '''
                    pm2 restart express-frontend || \
                    pm2 start index.js --name express-frontend
                    '''
                }
            }
        }
    }

    post {
        success {
            echo "✅ Backend and Frontend Deployment Successful"
        }
        failure {
            echo "❌ Deployment Failed"
        }
    }
}
